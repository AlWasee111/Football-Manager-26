<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.PlayerListController">
   <children>
      <ImageView fitHeight="655.0" fitWidth="1000.0">
         <image>
            <Image url="@../../../Images/FIFA-20-background.jpg" />
         </image>
      </ImageView>
      <ListView fx:id="PlayerList" layoutX="220.0" layoutY="176.0" prefHeight="367.0" prefWidth="583.0" stylesheets="@../../../Stylings/ListStyle.css" />
      <Label alignment="TOP_CENTER" layoutX="400.0" layoutY="66.0" prefHeight="45.0" prefWidth="200.0" text="Players" textFill="WHITE">
         <font>
            <Font name="Century Gothic Bold" size="56.0" />
         </font>
      </Label>
      <Label fx:id="playerLabel" alignment="TOP_CENTER" layoutX="331.0" layoutY="576.0" prefHeight="17.0" prefWidth="339.0" textFill="WHITE">
         <font>
            <Font name="Century Gothic Bold" size="31.0" />
         </font>
      </Label>
      <Button fx:id="backButton" layoutX="46.0" layoutY="583.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="43.0" prefWidth="98.0" stylesheets="@../../../Stylings/ListStyle.css" text="Back">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
      <Button fx:id="sellButton" layoutX="875.0" layoutY="583.0" mnemonicParsing="false" onAction="#sellPlayer" stylesheets="@../../../Stylings/ListStyle.css" text="Sell" visible="false">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
