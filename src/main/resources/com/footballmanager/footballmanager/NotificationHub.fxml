<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.NotificationHubController">
    <children>
        <ImageView fitHeight="655.0" fitWidth="1000.0">
            <image>
                <Image url="@../../../Images/FIFA-20-background.jpg" />
            </image>
        </ImageView>
        <ListView fx:id="NotificationList" layoutX="186.0" layoutY="163.0" prefHeight="391.0" prefWidth="662.0" stylesheets="@../../../Stylings/NotificationHub.css" />
        <Label alignment="TOP_CENTER" layoutX="245.0" layoutY="66.0" prefHeight="74.0" prefWidth="544.0" text="Updates" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="56.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="46.0" layoutY="583.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="43.0" prefWidth="98.0" stylesheets="@../../../Stylings/NotificationHub.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
    </children>
