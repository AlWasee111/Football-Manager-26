<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.InComingOffersController">
    <children>
        <ImageView fitHeight="900.0" fitWidth="1440.0">
            <image>
                <Image url="@../../../Images/bg02.jpg" />
            </image>
        </ImageView>
        <ListView fx:id="OfferList" layoutX="35.0" layoutY="302.0" prefHeight="465.0" prefWidth="858.0" stylesheets="@../../../Stylings/IncomingOffers.css" />
        <Label alignment="TOP_CENTER" layoutX="604.0" layoutY="28.0" prefHeight="95.0" prefWidth="197.0" text="Offers" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="56.0" />
            </font>
        </Label>
        <Label fx:id="playerLabel" alignment="TOP_CENTER" layoutX="551.0" layoutY="819.0" prefHeight="56.0" prefWidth="396.0" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="31.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="35.0" layoutY="813.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="50.0" prefWidth="130.0" stylesheets="@../../../Stylings/IncomingOffers.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="acceptButton" layoutX="1275.0" layoutY="813.0" mnemonicParsing="false" onAction="#sellPlayer" prefHeight="50.0" prefWidth="130.0" stylesheets="@../../../Stylings/IncomingOffers.css" text="My Actions" visible="false">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
      <ImageView fx:id="playerCard" fitHeight="530.0" fitWidth="469.0" layoutX="1007.0" layoutY="263.0" pickOnBounds="true" preserveRatio="true" />
        <ComboBox fx:id="posList" layoutX="20.0" layoutY="213.0" prefHeight="50.0" prefWidth="160.0" promptText="Position" stylesheets="@../../../Stylings/ListStyle.css" />
        <ComboBox fx:id="ratingList" layoutX="187.0" layoutY="213.0" prefHeight="50.0" prefWidth="160.0" promptText="Rating" stylesheets="@../../../Stylings/ListStyle.css" />
        <ComboBox fx:id="nationList" layoutX="359.0" layoutY="213.0" prefHeight="50.0" prefWidth="160.0" promptText="Nation" stylesheets="@../../../Stylings/ListStyle.css" />
        <Button fx:id="filterButton" layoutX="702.0" layoutY="213.0" mnemonicParsing="false" onAction="#filter" prefHeight="50.0" prefWidth="90.0" stylesheets="@../../../Stylings/ListStyle.css" text="Filter" />
        <ComboBox fx:id="salaryList" layoutX="527.0" layoutY="213.0" prefHeight="50.0" prefWidth="160.0" promptText="Salary" stylesheets="@../../../Stylings/ListStyle.css" />
        <Button fx:id="resetFilter" layoutX="810.0" layoutY="213.0" mnemonicParsing="false" onAction="#resetFilter" prefHeight="50.0" prefWidth="90.0" stylesheets="@../../../Stylings/ListStyle.css" text="Reset" />

    </children>
</AnchorPane>
