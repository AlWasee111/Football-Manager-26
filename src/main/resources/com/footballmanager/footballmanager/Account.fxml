<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.AccountController">
    <children>
        <ImageView fitHeight="900.0" fitWidth="1440.0">
            <image>
                <Image url="@../../../Images/bg02.jpg" />
            </image>
        </ImageView>
        <Label alignment="TOP_CENTER" layoutX="394.0" layoutY="63.0" prefHeight="93.0" prefWidth="612.0" text="Account Actions" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="50.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="35.0" layoutY="813.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="50.0" prefWidth="130.0" stylesheets="@../../../Stylings/ListStyle.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="changePass" layoutX="545.0" layoutY="301.0" mnemonicParsing="false" onAction="#ChangePassword" prefHeight="70.0" prefWidth="310.0" text="Change Password">
            <font>
                <Font name="Century Gothic" size="18.0" />
            </font>
        </Button>
        <Button fx:id="deleteAccButton" layoutX="545.0" layoutY="466.0" mnemonicParsing="false" onAction="#DeleteAccount" prefHeight="70.0" prefWidth="310.0" text="Delete account">
            <font>
                <Font name="Century Gothic" size="18.0" />
            </font>
        </Button>
    </children>
</AnchorPane>
