<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.AccountController">
    <children>
        <ImageView fitHeight="655.0" fitWidth="1000.0">
            <image>
                <Image url="@../../../Images/FIFA-20-background.jpg" />
            </image>
        </ImageView>
        <Label alignment="TOP_CENTER" layoutX="301.0" layoutY="68.0" prefHeight="33.0" prefWidth="399.0" text="Account Actions" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="45.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="46.0" layoutY="583.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="43.0" prefWidth="98.0" stylesheets="@../../../Stylings/ListStyle.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="changePass" layoutX="395.0" layoutY="202.0" mnemonicParsing="false" onAction="#ChangePassword" prefHeight="59.0" prefWidth="210.0" style="-fx-background-radius: 20;" text="Change Password">
            <font>
                <Font name="Century Gothic" size="18.0" />
            </font>
        </Button>
        <Button fx:id="deleteAccButton" layoutX="395.0" layoutY="298.0" mnemonicParsing="false" onAction="#DeleteAccount" prefHeight="59.0" prefWidth="210.0" style="-fx-background-radius: 20;" text="Delete account">
            <font>
                <Font name="Century Gothic" size="18.0" />
            </font>
        </Button>
    </children>
</AnchorPane>