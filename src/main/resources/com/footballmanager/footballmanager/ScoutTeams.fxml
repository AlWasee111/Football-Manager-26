<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.ScoutTeamsController">
    <children>
        <ImageView fitHeight="655.0" fitWidth="1000.0">
            <image>
                <Image url="@../../../Images/FIFA-20-background.jpg" />
            </image>
        </ImageView>
        <ListView fx:id="TeamList" layoutX="378.0" layoutY="140.0" prefHeight="411.0" prefWidth="575.0" stylesheets="@../../../Stylings/ScoutTeams.css" />
        <Label alignment="TOP_CENTER" layoutX="400.0" layoutY="31.0" prefHeight="45.0" prefWidth="200.0" text="Teams" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="56.0" />
            </font>
        </Label>
        <Label fx:id="TeamLabel" alignment="TOP_CENTER" layoutX="-1.0" layoutY="400.0" prefHeight="39.0" prefWidth="381.0" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="31.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="46.0" layoutY="583.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="43.0" prefWidth="98.0" stylesheets="@../../../Stylings/ScoutTeams.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="scoutButton" layoutX="875.0" layoutY="583.0" mnemonicParsing="false" onAction="#GoToScoutTeamPlayer" stylesheets="@../../../Stylings/ScoutTeams.css" text="Scout">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
      <ImageView fx:id="teamCrest" fitHeight="181.0" fitWidth="179.0" layoutX="100.0" layoutY="219.0" pickOnBounds="true" preserveRatio="true" />
    </children>
</AnchorPane>
