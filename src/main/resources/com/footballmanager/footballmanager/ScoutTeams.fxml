<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.footballmanager.footballmanager.ScoutTeamsController">
    <children>
        <ImageView fitHeight="900.0" fitWidth="1440.0">
         <image>
            <Image url="@../../../Images/bg02.jpg" />
         </image>
        </ImageView>
        <ListView fx:id="TeamList" layoutX="622.0" layoutY="234.0" prefHeight="454.0" prefWidth="734.0" stylesheets="@../../../Stylings/ScoutTeams.css" />
        <Label alignment="TOP_CENTER" layoutX="620.0" layoutY="37.0" prefHeight="45.0" prefWidth="200.0" text="Teams" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="56.0" />
            </font>
        </Label>
        <Label fx:id="TeamLabel" alignment="TOP_CENTER" layoutX="89.0" layoutY="535.0" prefHeight="74.0" prefWidth="491.0" textFill="WHITE">
            <font>
                <Font name="Century Gothic Bold" size="40.0" />
            </font>
        </Label>
        <Button fx:id="backButton" layoutX="35.0" layoutY="813.0" mnemonicParsing="false" onAction="#backToMenu" prefHeight="50.0" prefWidth="130.0" stylesheets="@../../../Stylings/ScoutTeams.css" text="Back">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
        <Button fx:id="scoutButton" layoutX="1275.0" layoutY="813.0" mnemonicParsing="false" onAction="#GoToScoutTeamPlayer" prefHeight="50.0" prefWidth="130.0" stylesheets="@../../../Stylings/ScoutTeams.css" text="Scout" visible="false">
            <font>
                <Font size="18.0" />
            </font>
        </Button>
      <ImageView fx:id="teamCrest" fitHeight="289.0" fitWidth="363.0" layoutX="190.0" layoutY="234.0" pickOnBounds="true" preserveRatio="true" />
    </children>
</AnchorPane>
